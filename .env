#añadido para que el navegador no bloque
FORCE_HTTPS=false
ASSET_URL=https://optenadvance.test
SESSION_SECURE_COOKIE=false

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file
